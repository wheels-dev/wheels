---
// Giscus config for https://giscus.app — backed by GitHub Discussions
// on wheels-dev/wheels repo, category 'Blog Comments'.
---

<section class="comments" aria-label="Comments">
  <h2>Comments</h2>
  <script
    src="https://giscus.app/client.js"
    data-repo="wheels-dev/wheels"
    data-repo-id="MDEwOlJlcG9zaXRvcnkxMjUwMzM1"
    data-category="Blog Comments"
    data-category-id="DIC_kwDOABMUH84C7GJT"
    data-mapping="pathname"
    data-strict="0"
    data-reactions-enabled="1"
    data-emit-metadata="0"
    data-input-position="bottom"
    data-theme="preferred_color_scheme"
    data-lang="en"
    data-loading="lazy"
    crossorigin="anonymous"
    async
  ></script>
</section>

<style>
  .comments { max-width: 720px; margin: 3rem auto 0; padding-top: 2rem; border-top: 1px solid var(--color-border); }
  .comments h2 { font-size: 1.25rem; margin: 0 0 1rem; }
</style>
