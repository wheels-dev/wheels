# .kamal/secrets — resolved at deploy time by wheels deploy.
#
# Populate from your secret manager, e.g. 1Password:
#   KAMAL_REGISTRY_PASSWORD=$(op read op://Deploy/Registry/password)
#   WHEELS_RELOAD_PASSWORD=$(op read op://Deploy/{{service_name}}/reload-password)
#
# Or set them directly for local development:
KAMAL_REGISTRY_PASSWORD=
WHEELS_RELOAD_PASSWORD=
