{
  "name": "{{appName}}",
  "lucee": {
    "version": "7.0.0.395"
  },
  "port": {{port}},
  "shutdownPort": {{shutdownPort}},
  "webroot": "./public",
  "openBrowser": {{openBrowser}},
  "jvm": {
    "maxMemory": "512m",
    "minMemory": "128m"
  },
  "urlRewrite": {
    "enabled": true,
    "routerFile": "index.cfm"
  },
  "admin": {
    "enabled": true,
    "password": "{{reloadPassword}}"
  },
  "enableLucee": true,
  "enableREST": false,
  "monitoring": {
    "enabled": false
  },
  "configuration": {
    "datasources": {{datasourcesBlock}},
    "mappings": {
      "/wheels": "../vendor/wheels",
      "/app": "../app",
      "/config": "../config",
      "/tests": "../tests"
    }
  }
}
